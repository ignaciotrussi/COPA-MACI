// ─── APP ROOT ─────────────────────────────────────────────────────────────────
export default function App() {
  const [view,      setView]      = useState("home");
  const [allScores, setAllScores] = useState(null);

  // Escuchar Firebase en tiempo real
  useEffect(() => {
    const q = query(collection(db, "scores"), orderBy("createdAt", "desc"));
    const unsub = onSnapshot(q, snap => {
      const fbScores = snap.docs.map(d => ({ id: d.id, ...d.data() }));
      // Combinar con seed (datos históricos fijos)
      const ids = new Set(fbScores.map(s => s.id));
      const combined = [
        ...fbScores,
        ...SEED.filter(s => !fbScores.some(fb =>
          fb.playerId===s.playerId && fb.dateLabel===s.dateLabel && fb.monthKey===s.monthKey
        )).map(s => ({ ...s, id: newId() }))
      ];
      setAllScores(combined);
    }, err => {
      console.error("Firebase error:", err);
      // Fallback: solo seed
      setAllScores(SEED.map(s => ({ ...s, id: newId() })));
    });
    return () => unsub();
  }, []);

  const handleSave = useCallback(async (score) => {
    try {
      await addDoc(collection(db, "scores"), { ...score, createdAt: serverTimestamp() });
    } catch (e) {
      console.error("Save error:", e);
      // Fallback local
      setAllScores(prev => [...(prev||[]), { ...score, id: newId() }]);
    }
  }, []);

  const handleDelete = useCallback(async (id) => {
    try {
      await deleteDoc(doc(db, "scores", id));
    } catch (e) {
      setAllScores(prev => prev.filter(s => s.id !== id));
    }
  }, []);

  if (!allScores) return (
    <div style={{ background:"#000", height:"100vh", display:"flex",
      alignItems:"center", justifyContent:"center" }}>
      <LogoSVG size={64} />
    </div>
  );

  return (
    <div style={{ background:"#000", minHeight:"100vh", maxWidth:480,
      margin:"0 auto", fontFamily:"'Barlow Condensed',sans-serif", color:"#fff" }}>
      {/* Header */}
      <div style={{ background:"#000", borderBottom:"1px solid #111",
        padding:"11px 16px 9px", position:"sticky", top:0, zIndex:10,
        display:"flex", alignItems:"center", gap:11 }}>
        <LogoSVG size={30} />
        <div>
          <div style={{ fontSize:17, fontWeight:900, letterSpacing:4, color:"#fff",
            lineHeight:1, fontFamily:"'Barlow Condensed',sans-serif" }}>COPA MACI</div>
          <div style={{ fontSize:8, color:"#333", letterSpacing:3 }}>TEMPORADA 2026</div>
        </div>
      </div>

      {/* Content */}
      <div style={{ padding:"16px 13px 32px" }}>
        {view==="home"      && <HomeView allScores={allScores} onNav={setView} />}
        {view==="scorecard" && <ScorecardView allScores={allScores} onSave={handleSave} onBack={()=>setView("home")} />}
        {view==="history"   && <HistoryView   allScores={allScores} onDelete={handleDelete} onBack={()=>setView("home")} />}
        {view==="gira"      && <GiraView onBack={()=>setView("home")} />}
      </div>
    </div>
  );
}
