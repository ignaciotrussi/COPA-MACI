// ── 2. CARGAR TARJETA (Wizard 3 pasos) ───────────────────────────────────────
function ScorecardView({ allScores, onSave, onBack }) {
  const [step,     setStep]     = useState(1);
  const [player,   setPlayer]   = useState(null);
  const [dateLabel,setDateLabel]= useState(todayLabel());
  const [course,   setCourse]   = useState(COURSE_NAMES[0]);
  const [tee,      setTee]      = useState("Blanco");
  const [handicap, setHandicap] = useState("");
  const [holes,    setHoles]    = useState(Array(18).fill(""));
  const [ld,       setLd]       = useState(false);
  const [ba,       setBa]       = useState(false);
  const [liveRank, setLiveRank] = useState([]);

  const pars       = COURSES[course] || Array(18).fill(4);
  const totalPar   = pars.reduce((a,b)=>a+b,0);
  const front9Par  = pars.slice(0,9).reduce((a,b)=>a+b,0);
  const back9Par   = pars.slice(9).reduce((a,b)=>a+b,0);
  const hcp        = parseInt(handicap)||0;
  const grossFront = holes.slice(0,9).reduce((a,h)=>a+(parseInt(h)||0),0);
  const grossBack  = holes.slice(9).reduce((a,h)=>a+(parseInt(h)||0),0);
  const grossTotal = grossFront + grossBack;
  const netScore   = grossTotal - hcp;
  const filled     = holes.filter(h=>h!=="").length;

  // Actualizar ranking en vivo mientras se cargan hoyos
  useEffect(() => {
    if (!player || filled === 0) return;
    const mk = monthKeyFromLabel(dateLabel);
    const monthScores = allScores.filter(s =>
      (s.monthKey||getMonthKey(s.dateLabel||"")) === mk
    );
    const tmp = [
      ...monthScores.filter(s => s.playerId !== player.id),
      { id:"__live__", monthKey:mk, playerId:player.id,
        netScore:grossTotal-hcp, back9:grossBack, longDrive:ld, bestApproach:ba }
    ];
    setLiveRank(rankMonth(tmp));
  }, [holes, ld, ba, dateLabel]);

  function finish() {
    const mk = monthKeyFromLabel(dateLabel);
    onSave({
      monthKey:    mk,
      dateLabel,
      playerId:    player.id,
      netScore:    grossTotal - hcp,
      back9:       grossBack,
      longDrive:   ld,
      bestApproach:ba,
      course,
      tee,
      handicap:    hcp,
      holes:       holes.map(h => parseInt(h)||0),
