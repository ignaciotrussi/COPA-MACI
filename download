// ─── LÓGICA DE PUNTOS ─────────────────────────────────────────────────────────
// monthKey = "YYYY-MM"
function getMonthKey(dateStr) {
  // dateStr puede ser "8 Mar", "2026-04-12", etc.
  // Normalizamos: si tiene formato "D Mes" lo mapeamos
  const months = { Jan:"01",Feb:"01",Mar:"03",Abr:"04",Apr:"04",May:"05",
                   Jun:"06",Jul:"07",Ago:"08",Aug:"08",Sep:"09",Oct:"10",
                   Nov:"11",Dic:"12",Dec:"12" };
  const parts = dateStr.trim().split(/[\s\-\/]/);
  if (parts.length >= 2) {
    const mon = months[parts[1]] || parts[1];
    const yr  = parts[2] || "2026";
    return `${yr}-${mon}`;
  }
  return "2026-00";
}

// Por mes: tomar el mejor score neto de cada jugador
// Empate → menor back9 gana
function bestPerPlayer(monthScores) {
  const map = {};
  monthScores.forEach(s => {
    const cur = map[s.playerId];
    if (!cur) {
      map[s.playerId] = { ...s };
    } else {
      const better = s.netScore < cur.netScore ||
        (s.netScore === cur.netScore && (s.back9 ?? 999) < (cur.back9 ?? 999));
      map[s.playerId] = better
        ? { ...s, longDrive: s.longDrive || cur.longDrive, bestApproach: s.bestApproach || cur.bestApproach }
        : { ...cur, longDrive: cur.longDrive || s.longDrive, bestApproach: cur.bestApproach || s.bestApproach };
    }
  });
  return Object.values(map);
}

function rankMonth(monthScores) {
  const bests = bestPerPlayer(monthScores);
  return [...bests]
    .sort((a, b) => a.netScore !== b.netScore
      ? a.netScore - b.netScore
      : (a.back9 ?? 999) - (b.back9 ?? 999))
    .map((r, i) => ({
      ...r,
      position: i + 1,
      points: (i < 6 ? PTS_TABLE[i] : i < 12 ? 2 : 0)
            + (r.longDrive ? 1 : 0)
            + (r.bestApproach ? 1 : 0),
    }));
}

// Totales anuales por jugador
function annualTotals(allScores) {
  // Agrupar por mes
  const byMonth = {};
  allScores.forEach(s => {
    const mk = s.monthKey || getMonthKey(s.dateLabel || "");
    if (!byMonth[mk]) byMonth[mk] = [];
    byMonth[mk].push(s);
  });

  const playerPts = {};
  PLAYERS.forEach(p => { playerPts[p.id] = { pts:0, played:0, wins:0, history:[] }; });

  Object.entries(byMonth).forEach(([mk, ms]) => {
    const ranked = rankMonth(ms);
    ranked.forEach(r => {
      if (!playerPts[r.playerId]) return;
      playerPts[r.playerId].pts    += r.points;
      playerPts[r.playerId].played += 1;
      if (r.position === 1) playerPts[r.playerId].wins += 1;
      playerPts[r.playerId].history.push({ monthKey:mk, position:r.position, points:r.points, netScore:r.netScore });
    });
  });

  return PLAYERS.map(p => ({
    ...p,
    ...playerPts[p.id],
    avg: playerPts[p.id].played ? (playerPts[p.id].pts / playerPts[p.id].played).toFixed(1) : null,
  })).sort((a, b) => b.pts - a.pts);
}

